{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IP Guard",
  "version": "0.1.0",
  "identifier": "com.utauu.ipguard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "IP Guard",
        "width": 300,
        "height": 450,
        "minWidth": 300,
        "minHeight": 450,
        "maxWidth": 300,
        "maxHeight": 450,
        "visible": false,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "category": "Utility",
    "shortDescription": "Menu-bar IP region guard for macOS",
    "longDescription": "Detects whether your current public IP is in your allowlisted regions and warns you when activating monitored apps."
  }
}
